# === Required: At least one LLM provider ===
OPENROUTER_API_KEY=sk-or-v1-...     # Free: 50/day, 1000/day after $10 deposit
GROQ_API_KEY=gsk_...                 # Free: 14400 requests/day

# === Required for human notifications ===
TELEGRAM_BOT_TOKEN=123456:ABC-DEF... # Get from @BotFather on Telegram
TELEGRAM_CHAT_ID=123456789           # Your Telegram user ID

# === Optional ===
OLLAMA_HOST=http://localhost:11434   # Local fallback
DEPLOY=true                          # Set to true for HF Spaces / Docker
PORT=8080                            # Health server port
DATA_DIR=data                        # Persistent data directory
LOG_LEVEL=DEBUG                      # DEBUG, INFO, WARNING, ERROR
